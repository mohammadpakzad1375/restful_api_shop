                                    "category_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "image": {
                                        "description": "Post image",
                                        "type": "string",
                                        "format": "binary"
                                    },
                                    "commentable": {
                                        "type": "integer",
                                        "example": 1,
                                        "enum": [
                                            0,
                                            1
                                        ]
                                    },
                                    "published_at": {
                                        "description": "Unix timestamp",
                                        "type": "integer",
                                        "example": 1782331200
                                    },
                                    "tags": {
                                        "type": "string",
                                        "example": "هوش مصنوعی-فناوری-برنامه نویسی-AI-تکنولوژی"
                                    },
                                    "status": {
                                        "description": "Post status (optional)",
